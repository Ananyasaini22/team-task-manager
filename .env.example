# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# MongoDB connection string from MongoDB Atlas (Free tier M0 works great)
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/

# Database name (will be created automatically)
DB_NAME=taskmanager

# Secret key for signing JWTs — generate a long random string
# Run: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-a-long-random-secret-key
